{
  "strategy_id": "tokyo_mean_reversion_v3",
  "name": "USDJPY Tokyo Session Mean Reversion V3",
  "broker": "oanda_demo",
  "instrument": "USD_JPY",
  "starting_equity_usd": 50000,
  "data": {
    "source": "oanda_m1_csv",
    "timeframe": "M1",
    "pip_size": 0.01,
    "price_basis": "bid_for_signals_ask_bid_for_execution",
    "weekend_gap_handling": {
      "skip_indicator_across_gaps_over_minutes": 5
    },
    "derived_timeframes": {
      "M5": "aggregate_from_M1",
      "M15": "aggregate_from_M1",
      "daily_ny_close_boundary_utc_hour": 22
    }
  },
  "run_sequence": [
    {
      "label": "50k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/USDJPY_M1_50k_new.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_50k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_50k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_50k_equity.csv"
    },
    {
      "label": "250k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_250k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_250k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_250k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_250k_equity.csv"
    }
  ],
  "breakout_analysis_output": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_meanrev_v3_breakout_analysis.json",
  "session_filter": {
    "enabled": true,
    "timezone_reference": "UTC",
    "tokyo_session_jst": {
      "start": "00:00",
      "end": "09:00"
    },
    "tokyo_session_utc": {
      "start": "15:00_prev_day",
      "end": "00:00"
    },
    "trade_only_inside_session": true,
    "force_close_at_session_end": true
  },
  "indicators": {
    "fibonacci_pivots_daily": {
      "enabled": true,
      "day_boundary": "ny_close_17_est",
      "recalc": "once_per_day_at_session_start",
      "formulas": {
        "P": "(H+L+C)/3",
        "R1": "P + 0.382*(H-L)",
        "R2": "P + 0.618*(H-L)",
        "R3": "P + 1.000*(H-L)",
        "S1": "P - 0.382*(H-L)",
        "S2": "P - 0.618*(H-L)",
        "S3": "P - 1.000*(H-L)"
      }
    },
    "bollinger_bands": {
      "timeframe": "M5",
      "period": 20,
      "std_dev": 2.0,
      "source": "close",
      "outputs": [
        "upper_band",
        "middle_band",
        "lower_band"
      ]
    },
    "parabolic_sar": {
      "timeframe": "M1",
      "af_start": 0.02,
      "af_increment": 0.02,
      "af_max": 0.2,
      "outputs": [
        "sar_value",
        "sar_direction"
      ],
      "direction_definitions": {
        "bullish": "sar_below_price",
        "bearish": "sar_above_price"
      }
    },
    "rsi": {
      "timeframe": "M5",
      "period": 14,
      "source": "close",
      "overbought": 70,
      "oversold": 30
    },
    "atr": {
      "timeframe": "M15",
      "period": 14,
      "max_threshold_price_units": 0.30
    },
    "bb_width_regime_filter": {
      "formula": "(upper_band-lower_band)/middle_band",
      "percentile_lookback_m5_bars": 100,
      "ranging_percentile": 0.80,
      "trending_definition": "bb_width >= rolling_percentile_cutoff",
      "ranging_definition": "bb_width < rolling_percentile_cutoff"
    }
  },
  "entry_rules": {
    "long": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.30,
      "price_zone": {
        "rule": "close <= S1 + tolerance",
        "tolerance_pips": 10.0
      },
      "bollinger_condition": "close<=lower_band OR low<=lower_band",
      "sar_flip_condition": "sar_flipped_to_bullish_within_last_n_m1",
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 35,
        "bonus_threshold": 30
      },
      "confluence_scoring": {
        "minimum_score": 2,
        "components": [
          {
            "name": "price_at_or_below_S1",
            "score": 1
          },
          {
            "name": "price_touching_lower_bb",
            "score": 1
          },
          {
            "name": "sar_flip_bullish",
            "score": 1
          },
          {
            "name": "rsi_below_30",
            "score": 1
          },
          {
            "name": "price_at_or_below_S2",
            "score": 1
          }
        ]
      }
    },
    "short": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.30,
      "price_zone": {
        "rule": "close >= R1 - tolerance",
        "tolerance_pips": 10.0
      },
      "bollinger_condition": "close>=upper_band OR high>=upper_band",
      "sar_flip_condition": "sar_flipped_to_bearish_within_last_n_m1",
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 65,
        "bonus_threshold": 70
      },
      "confluence_scoring": {
        "minimum_score": 2,
        "components": [
          {
            "name": "price_at_or_above_R1",
            "score": 1
          },
          {
            "name": "price_touching_upper_bb",
            "score": 1
          },
          {
            "name": "sar_flip_bearish",
            "score": 1
          },
          {
            "name": "rsi_above_70",
            "score": 1
          },
          {
            "name": "price_at_or_above_R2",
            "score": 1
          }
        ]
      }
    }
  },
  "exit_rules": {
    "take_profit": {
      "primary_target": "daily_pivot_P",
      "partial_logic": [
        {
          "when": "long_from_S2_zone",
          "partial_tp_level": "S1",
          "partial_close_pct": 0.5,
          "final_tp_level": "P"
        },
        {
          "when": "short_from_R2_zone",
          "partial_tp_level": "R1",
          "partial_close_pct": 0.5,
          "final_tp_level": "P"
        }
      ],
      "minimum_tp_distance_pips": 8.0,
      "if_pivot_too_close_extend_to": "opposite_R1_or_S1"
    },
    "stop_loss": {
      "long": "S2-5p (or S3-5p if entry at S2)",
      "short": "R2+5p (or R3+5p if entry at R2)",
      "hard_max_sl_pips": 20.0,
      "minimum_sl_pips": 8.0
    },
    "trailing_stop": {
      "enabled": true,
      "activate_after_profit_pips": 8.0,
      "trail_distance_pips": 6.0,
      "never_widen": true
    },
    "time_exit": {
      "force_close_at_tokyo_end": true,
      "hold_through_london_open": false
    }
  },
  "position_sizing": {
    "risk_per_trade_pct": 0.75,
    "units_formula": "floor((equity * risk_pct) / (sl_pips * (0.01/current_price)))",
    "max_units": 500000,
    "max_concurrent_positions": 2
  },
  "trade_management": {
    "max_trades_per_session": 4,
    "stop_after_consecutive_losses": 3,
    "min_time_between_entries_minutes": 10,
    "no_reentry_same_direction_after_stop_minutes": 30,
    "disable_entries_if_move_from_tokyo_open_range_exceeds_pips": 30.0,
    "breakout_detection_mode": "rolling",
    "rolling_window_minutes": 60,
    "rolling_range_threshold_pips": 40.0,
    "cooldown_minutes": 15
  },
  "execution_model": {
    "long_entry_price": "ask",
    "short_entry_price": "bid",
    "long_exit_price": "bid",
    "short_exit_price": "ask",
    "spread_application": "apply_current_spread_on_fill",
    "pip_size": 0.01,
    "spread_pips": 1.5
  },
  "outputs": {
    "report_format": "json",
    "trade_log_format": "csv",
    "equity_curve_format": "csv"
  }
}
