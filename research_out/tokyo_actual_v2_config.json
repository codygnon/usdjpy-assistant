{
  "strategy_id": "tokyo_actual_v2",
  "name": "USDJPY Tokyo Session Mean Reversion v2",
  "broker": "oanda_demo",
  "instrument": "USD_JPY",
  "starting_equity_usd": 100000,
  "data": {
    "source": "oanda_m1_csv",
    "timeframe": "M1",
    "pip_size": 0.01,
    "price_basis": "bid_for_signals_ask_bid_for_execution",
    "weekend_gap_handling": {
      "skip_indicator_across_gaps_over_minutes": 5
    },
    "derived_timeframes": {
      "M5": "aggregate_from_M1",
      "M15": "aggregate_from_M1",
      "daily_ny_close_boundary_utc_hour": 22
    }
  },
  "run_sequence": [
    {
      "label": "50k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_50k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_50k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_50k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_50k_equity.csv"
    },
    {
      "label": "250k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_250k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_250k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_250k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_250k_equity.csv"
    },
    {
      "label": "500k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_500k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_500k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_500k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_500k_equity.csv"
    },
    {
      "label": "1000k",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_1000k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_1000k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_1000k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_actual_v2_1000k_equity.csv"
    }
  ],
  "session_filter": {
    "enabled": true,
    "timezone_reference": "UTC",
    "session_start_utc": "00:00",
    "session_end_utc": "09:00",
    "entry_start_utc": "00:00",
    "entry_end_utc": "09:00",
    "allowed_trading_days": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "trade_only_inside_session": true,
    "force_close_at_session_end": true,
    "lunch_block_enabled": true,
    "lunch_block_start_utc": "02:30",
    "lunch_block_end_utc": "03:30"
  },
  "indicators": {
    "fibonacci_pivots_daily": {
      "enabled": true,
      "day_boundary": "ny_close_17_est",
      "recalc": "once_per_day_at_session_start"
    },
    "bollinger_bands": {
      "timeframe": "M5",
      "period": 20,
      "std_dev": 2.0,
      "source": "close"
    },
    "parabolic_sar": {
      "timeframe": "M1",
      "af_start": 0.02,
      "af_increment": 0.02,
      "af_max": 0.2
    },
    "rsi": {
      "timeframe": "M5",
      "period": 14,
      "source": "close",
      "overbought": 70,
      "oversold": 30
    },
    "atr": {
      "timeframe": "M15",
      "period": 14,
      "max_threshold_price_units": 0.2,
      "use_as_hard_gate": false
    },
    "bb_width_regime_filter": {
      "formula": "(upper_band-lower_band)/middle_band",
      "lookback_m5_bars": 3,
      "mode": "expanding3",
      "trending_definition": "all prior 3 BB width values increasing",
      "ranging_definition": "not increasing over prior 3"
    }
  },
  "entry_rules": {
    "scoring_model": "tokyo_v2",
    "core_gate": {
      "required_count": 0,
      "use_zone": false,
      "use_bb_touch": false,
      "use_sar_flip": false,
      "use_rsi_soft": false
    },
    "long": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.2,
      "price_zone": {
        "rule": "close <= S1 + tolerance",
        "tolerance_pips": 5
      },
      "bollinger_condition": "close<=lower_band OR low<=lower_band",
      "sar_flip_condition": "sar_flipped_to_bullish_within_last_n_m1",
      "sar_flip_lookback_bars": 10,
      "rsi_soft_filter": {
        "entry_soft_threshold": 35,
        "bonus_threshold": 25
      },
      "confluence_scoring": {
        "minimum_score": 3
      }
    },
    "short": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.2,
      "price_zone": {
        "rule": "close >= R1 - tolerance",
        "tolerance_pips": 5
      },
      "bollinger_condition": "close>=upper_band OR high>=upper_band",
      "sar_flip_condition": "sar_flipped_to_bearish_within_last_n_m1",
      "sar_flip_lookback_bars": 10,
      "rsi_soft_filter": {
        "entry_soft_threshold": 65,
        "bonus_threshold": 75
      },
      "confluence_scoring": {
        "minimum_score": 3
      }
    }
  },
  "entry_confirmation": {
    "enabled": false,
    "type": "m1",
    "window_bars": 0
  },
  "exit_rules": {
    "take_profit": {
      "mode": "pivot_v2",
      "primary_target": "daily_pivot_P",
      "minimum_tp_distance_pips": 8.0,
      "partial_close_pct": 0.5,
      "breakeven_offset_pips": 0.0
    },
    "stop_loss": {
      "hard_max_sl_pips": 25.0,
      "minimum_sl_pips": 8.0,
      "buffer_pips": 5.0
    },
    "trailing_stop": {
      "enabled": true,
      "activate_after_profit_pips": 8.0,
      "trail_distance_pips": 6.0,
      "never_widen": true,
      "requires_tp1_hit": false
    },
    "time_exit": {
      "force_close_at_tokyo_end": true,
      "hold_through_london_open": false,
      "time_decay_minutes": 9999,
      "time_decay_profit_cap_pips": 0.0
    }
  },
  "position_sizing": {
    "risk_per_trade_pct": 0.75,
    "units_formula": "floor((equity * risk_pct) / (sl_pips * (0.01/current_price)))",
    "max_units": 500000,
    "max_concurrent_positions": 2
  },
  "trade_management": {
    "max_trades_per_session": 0,
    "stop_after_consecutive_losses": 0,
    "consecutive_loss_pause": {
      "enabled": true,
      "consecutive_losses": 2,
      "pause_minutes": 30
    },
    "session_loss_stop_pct": 0.0,
    "min_time_between_entries_minutes": 5,
    "no_reentry_same_direction_after_stop_minutes": 15,
    "disable_entries_if_move_from_tokyo_open_range_exceeds_pips": 40.0,
    "breakout_detection_mode": "from_open",
    "rolling_window_minutes": 60,
    "rolling_range_threshold_pips": 40.0,
    "cooldown_minutes": 15
  },
  "execution_model": {
    "long_entry_price": "ask",
    "short_entry_price": "bid",
    "long_exit_price": "bid",
    "short_exit_price": "ask",
    "spread_application": "apply_current_spread_on_fill",
    "pip_size": 0.01,
    "spread_pips": 1.6,
    "spread_mode": "realistic",
    "spread_min_pips": 1.0,
    "spread_max_pips": 3.5,
    "max_entry_spread_pips": 10.0
  },
  "margin_model": {
    "enabled": true,
    "leverage": 50.0,
    "buffer_pct": 0.0
  },
  "adx_filter": {
    "enabled": false,
    "period": 14,
    "timeframe": "M15",
    "max_adx_for_entry": 99.0
  },
  "confluence_combo_filter": {
    "enabled": false,
    "mode": "allowlist",
    "allowed_combos": [],
    "blocked_combos": []
  },
  "daily_range_filter": {
    "enabled": false,
    "min_prior_day_range_pips": 0,
    "max_prior_day_range_pips": 999
  },
  "entry_improvement": {
    "enabled": false,
    "long_offset_from_confirm_low_pips": 1,
    "short_offset_from_confirm_high_pips": 1,
    "fill_window_candles": 3,
    "if_not_filled": "expire"
  },
  "entry_chase_filter": {
    "enabled": false,
    "max_chase_pips": 99
  },
  "signal_strength_tracking": {
    "enabled": false,
    "filter_on_it": false,
    "components": {}
  },
  "regime_gate": {
    "enabled": false
  },
  "confluence_quality": {
    "enabled": false
  },
  "hour_preference": {
    "enabled": false,
    "multipliers": {}
  },
  "drawdown_adaptive_sizing": {
    "enabled": false
  },
  "news_filter": {
    "enabled": false
  },
  "early_exit": {
    "enabled": false
  },
  "late_session_management": {
    "enabled": false,
    "minutes_before_end": 0,
    "close_if_no_tp1_and_pips_below": -999,
    "tp1_hit_tighten_trail_pips": 0
  },
  "rejection_bonus": {
    "enabled": false
  },
  "session_envelope": {
    "enabled": false
  },
  "rsi_divergence_tracking": {
    "enabled": false,
    "log_only": true
  },
  "trend_regime_skip": {
    "enabled": false,
    "lookback_days": 3,
    "max_directional_move_pips": 999,
    "action": "skip_session"
  },
  "outputs": {
    "report_format": "json",
    "trade_log_format": "csv",
    "equity_curve_format": "csv"
  }
}
