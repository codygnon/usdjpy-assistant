{
  "strategy_id": "tokyo_mean_reversion_v7",
  "name": "USDJPY Tokyo Mean Reversion V7 (V4 middle-ground)",
  "broker": "oanda_demo",
  "instrument": "USD_JPY",
  "starting_equity_usd": 100000,
  "data": {
    "source": "oanda_m1_csv",
    "timeframe": "M1",
    "pip_size": 0.01,
    "price_basis": "bid_for_signals_ask_bid_for_execution",
    "weekend_gap_handling": {
      "skip_indicator_across_gaps_over_minutes": 5
    },
    "derived_timeframes": {
      "M5": "aggregate_from_M1",
      "M15": "aggregate_from_M1",
      "daily_ny_close_boundary_utc_hour": 22
    }
  },
  "run_sequence": [
    {
      "label": "1000k_realism_maxopen3_exit_40_12_8",
      "input_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/USDJPY_M1_OANDA_1000k.csv",
      "output_json": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_v14_realism_maxopen3_exit_40_12_8_1000k_report.json",
      "output_trades_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_v14_realism_maxopen3_exit_40_12_8_1000k_trades.csv",
      "output_equity_csv": "/Users/codygnon/Documents/usdjpy_assistant/research_out/tokyo_v14_realism_maxopen3_exit_40_12_8_1000k_equity.csv"
    }
  ],
  "session_filter": {
    "enabled": true,
    "timezone_reference": "UTC",
    "session_start_utc": "16:00",
    "session_end_utc": "22:00",
    "allowed_trading_days": [
      "Tuesday",
      "Wednesday",
      "Friday"
    ],
    "trade_only_inside_session": true,
    "force_close_at_session_end": true
  },
  "indicators": {
    "fibonacci_pivots_daily": {
      "enabled": true,
      "day_boundary": "ny_close_17_est",
      "recalc": "once_per_day_at_session_start",
      "formulas": {
        "P": "(H+L+C)/3",
        "R1": "P + 0.382*(H-L)",
        "R2": "P + 0.618*(H-L)",
        "R3": "P + 1.000*(H-L)",
        "S1": "P - 0.382*(H-L)",
        "S2": "P - 0.618*(H-L)",
        "S3": "P - 1.000*(H-L)"
      }
    },
    "bollinger_bands": {
      "timeframe": "M5",
      "period": 25,
      "std_dev": 2.2,
      "source": "close"
    },
    "parabolic_sar": {
      "timeframe": "M1",
      "af_start": 0.02,
      "af_increment": 0.02,
      "af_max": 0.2
    },
    "rsi": {
      "timeframe": "M5",
      "period": 14,
      "source": "close",
      "overbought": 70,
      "oversold": 30
    },
    "atr": {
      "timeframe": "M15",
      "period": 14,
      "max_threshold_price_units": 0.3
    },
    "bb_width_regime_filter": {
      "formula": "(upper_band-lower_band)/middle_band",
      "percentile_lookback_m5_bars": 100,
      "ranging_percentile": 0.8,
      "trending_definition": "bb_width >= rolling_percentile_cutoff",
      "ranging_definition": "bb_width < rolling_percentile_cutoff"
    }
  },
  "entry_rules": {
    "long": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.3,
      "price_zone": {
        "rule": "close <= S1 + tolerance",
        "tolerance_pips": 20
      },
      "bollinger_condition": "close<=lower_band OR low<=lower_band",
      "sar_flip_condition": "sar_flipped_to_bullish_within_last_n_m1",
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 35,
        "bonus_threshold": 30
      },
      "confluence_scoring": {
        "minimum_score": 2
      }
    },
    "short": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.3,
      "price_zone": {
        "rule": "close >= R1 - tolerance",
        "tolerance_pips": 20
      },
      "bollinger_condition": "close>=upper_band OR high>=upper_band",
      "sar_flip_condition": "sar_flipped_to_bearish_within_last_n_m1",
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 65,
        "bonus_threshold": 70
      },
      "confluence_scoring": {
        "minimum_score": 2
      }
    }
  },
  "exit_rules": {
    "take_profit": {
      "primary_target": "daily_pivot_P",
      "minimum_tp_distance_pips": 8.0,
      "partial_close_pct": 0.4,
      "partial_tp_atr_mult": 0.5,
      "partial_tp_min_pips": 6,
      "partial_tp_max_pips": 12,
      "breakeven_offset_pips": 2.0,
      "mode": "partial"
    },
    "stop_loss": {
      "hard_max_sl_pips": 35,
      "minimum_sl_pips": 12,
      "buffer_pips": 8
    },
    "trailing_stop": {
      "enabled": true,
      "activate_after_profit_pips": 12,
      "trail_distance_pips": 8,
      "never_widen": true,
      "requires_tp1_hit": true
    },
    "time_exit": {
      "force_close_at_tokyo_end": true,
      "hold_through_london_open": false,
      "time_decay_minutes": 120,
      "time_decay_profit_cap_pips": 3.0
    }
  },
  "position_sizing": {
    "risk_per_trade_pct": 2.0,
    "units_formula": "floor((equity * risk_pct) / (sl_pips * (0.01/current_price)))",
    "max_units": 500000,
    "max_concurrent_positions": 3
  },
  "trade_management": {
    "max_trades_per_session": 4,
    "stop_after_consecutive_losses": 3,
    "session_loss_stop_pct": 1.5,
    "min_time_between_entries_minutes": 10,
    "no_reentry_same_direction_after_stop_minutes": 30,
    "disable_entries_if_move_from_tokyo_open_range_exceeds_pips": 30.0,
    "breakout_detection_mode": "rolling",
    "rolling_window_minutes": 60,
    "rolling_range_threshold_pips": 40.0,
    "cooldown_minutes": 15
  },
  "execution_model": {
    "long_entry_price": "ask",
    "short_entry_price": "bid",
    "long_exit_price": "bid",
    "short_exit_price": "ask",
    "spread_application": "apply_current_spread_on_fill",
    "pip_size": 0.01,
    "spread_pips": 1.6,
    "spread_mode": "realistic",
    "spread_min_pips": 1.0,
    "spread_max_pips": 3.5,
    "max_entry_spread_pips": 3.0
  },
  "outputs": {
    "report_format": "json",
    "trade_log_format": "csv",
    "equity_curve_format": "csv"
  },
  "regime_gate": {
    "enabled": false
  },
  "confluence_quality": {
    "enabled": false
  },
  "hour_preference": {
    "enabled": false,
    "multipliers": {}
  },
  "drawdown_adaptive_sizing": {
    "enabled": false
  },
  "adx_filter": {
    "enabled": true,
    "period": 14,
    "timeframe": "M15",
    "max_adx_for_entry": 35
  },
  "confluence_combo_filter": {
    "enabled": true,
    "mode": "blocklist",
    "blocked_combos": [
      "ABCD"
    ],
    "allowed_combos": []
  },
  "daily_range_filter": {
    "enabled": false,
    "min_prior_day_range_pips": 8,
    "max_prior_day_range_pips": 120
  },
  "entry_improvement": {
    "enabled": false,
    "long_offset_from_confirm_low_pips": 1,
    "short_offset_from_confirm_high_pips": 1,
    "fill_window_candles": 3,
    "if_not_filled": "expire"
  },
  "entry_chase_filter": {
    "enabled": false,
    "max_chase_pips": 2
  },
  "signal_strength_tracking": {
    "enabled": true,
    "filter_on_it": false,
    "components": {
      "confluence_count": {
        "2": 1,
        "3": 2,
        "4": 3,
        "5": 4
      },
      "bb_penetration_bonus_pips": 2,
      "rsi_extreme_bonus_threshold": 25,
      "deep_pivot_zone": true,
      "same_candle_sar_flip": true,
      "favorable_hour": [
        17,
        18,
        21
      ]
    }
  },
  "entry_confirmation": {
    "enabled": true,
    "type": "m1",
    "window_bars": 12
  },
  "news_filter": {
    "enabled": false
  },
  "margin_model": {
    "enabled": true,
    "leverage": 33.3,
    "buffer_pct": 0.0
  }
}