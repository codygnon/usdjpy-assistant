  "session_filter": {
    "enabled": true,
    "timezone_reference": "UTC",
    "session_start_utc": "16:30",
    "session_end_utc": "22:00",
    "allowed_trading_days": [
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "trade_only_inside_session": true,
    "force_close_at_session_end": true
  },
  "indicators": {
    "fibonacci_pivots_daily": {
      "enabled": true,
      "day_boundary": "ny_close_17_est"
    },
    "bollinger_bands": {
      "timeframe": "M5",
      "period": 20,
      "std_dev": 2.0,
      "source": "close"
    },
    "parabolic_sar": {
      "timeframe": "M1",
      "af_start": 0.02,
      "af_increment": 0.02,
      "af_max": 0.2
    },
    "rsi": {
      "timeframe": "M5",
      "period": 14,
      "source": "close",
      "overbought": 70,
      "oversold": 30
    },
    "atr": {
      "timeframe": "M15",
      "period": 14,
      "max_threshold_price_units": 0.3
    },
    "bb_width_regime_filter": {
      "formula": "(upper_band-lower_band)/middle_band",
      "percentile_lookback_m5_bars": 100,
      "ranging_percentile": 0.8
    }
  },
  "entry_rules": {
    "long": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.3,
      "price_zone": {
        "rule": "close <= S1 + tolerance",
        "tolerance_pips": 10.0
      },
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 35,
        "bonus_threshold": 30
      },
      "confluence_scoring": {
        "minimum_score": 2
      }
    },
    "short": {
      "require_session_filter": true,
      "require_regime": "ranging",
      "require_atr_max": 0.3,
      "price_zone": {
        "rule": "close >= R1 - tolerance",
        "tolerance_pips": 10.0
      },
      "sar_flip_lookback_bars": 12,
      "rsi_soft_filter": {
        "entry_soft_threshold": 65,
        "bonus_threshold": 70
      },
      "confluence_scoring": {
        "minimum_score": 2
      }
    }
  },
  "exit_rules": {
    "take_profit": {
      "primary_target": "daily_pivot_P",
      "minimum_tp_distance_pips": 8.0,
      "partial_close_pct": 0.5,
      "partial_tp_atr_mult": 0.5,
      "partial_tp_min_pips": 6.0,
      "partial_tp_max_pips": 12.0,
      "breakeven_offset_pips": 2.0
    },
    "stop_loss": {
      "hard_max_sl_pips": 28.0,
      "minimum_sl_pips": 10.0,
      "buffer_pips": 8.0
    },
    "trailing_stop": {
      "enabled": true,
      "activate_after_profit_pips": 12.0,
      "trail_distance_pips": 8.0,
      "never_widen": true
    },
    "time_exit": {
      "force_close_at_tokyo_end": true,
      "hold_through_london_open": false,
      "time_decay_minutes": 120,
      "time_decay_profit_cap_pips": 3.0
    }
  },
  "position_sizing": {
    "risk_per_trade_pct": 0.5,
    "units_formula": "floor((equity * risk_pct) / (sl_pips * (0.01/current_price)))",
    "max_units": 500000,
    "max_concurrent_positions": 2
  },
  "trade_management": {
    "max_trades_per_session": 4,
    "session_loss_stop_pct": 1.5,
    "min_time_between_entries_minutes": 10,
    "no_reentry_same_direction_after_stop_minutes": 30,
    "disable_entries_if_move_from_tokyo_open_range_exceeds_pips": 30.0,
    "breakout_detection_mode": "rolling",
    "rolling_window_minutes": 60,
    "rolling_range_threshold_pips": 40.0,
    "cooldown_minutes": 15
  },
  "regime_gate": {
    "enabled": true,
    "atr_fast_period": 14,
    "atr_slow_period": 50,
    "atr_ratio_trending_threshold": 1.3,
    "atr_ratio_calm_threshold": 0.8,
    "bb_width_high_pctile": 70,
    "bb_width_low_pctile": 40,
    "bb_width_lookback": 200,
    "adx_period": 14,
    "adx_trending_threshold": 25,
    "adx_ranging_threshold": 20,
    "favorable_min_score": 1,
    "neutral_min_score": 0,
    "unfavorable_max_score": -1,
    "neutral_size_multiplier": 0.5
  },
  "confluence_quality": {
    "enabled": true,
    "top_combos": [
      "BCD",
      "ABC",
      "ABCDE"
    ],
    "bottom_combos": [
      "ACD",
      "ABCD",
      "AC"
    ],
    "high_quality_size_mult": 1.0,
    "medium_quality_size_mult": 0.75,
    "low_quality_skip": true
  },
  "hour_preference": {
    "enabled": true,
    "multipliers": {
      "16": 0.5,
      "17": 1.0,
      "18": 1.0,
      "19": 0.75,
      "20": 0.75,
      "21": 1.0
    }
  },
  "drawdown_adaptive_sizing": {
    "enabled": true,
    "tier_1_dd_pct": 2.0,
    "tier_1_size_reduction": 0.25,
    "tier_2_dd_pct": 4.0,
    "tier_2_size_reduction": 0.5,
    "tier_3_dd_pct": 6.0,
    "tier_3_action": "pause",
    "resume_dd_pct": 4.0
  },
  "second_half_management": {
    "selected_option": "B",
    "reason": "Phase A shows second half net positive overall while breakeven-stop bucket is the largest outcome bucket."
  },
  "execution_model": {
    "long_entry_price": "ask",
    "short_entry_price": "bid",
    "long_exit_price": "bid",
    "short_exit_price": "ask",
    "spread_application": "apply_current_spread_on_fill",
    "pip_size": 0.01,
    "spread_pips": 1.5
  },
  "outputs": {
    "report_format": "json",
    "trade_log_format": "csv",
    "equity_curve_format": "csv"
  }
}